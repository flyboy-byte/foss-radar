# GitHub Personal Access Token (optional but recommended)
# Without: 60 API requests/hour  |  With: 5,000/hour
# Scopes needed: none (public repos only)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Port the server listens on (default: 5000)
PORT=5000

# Set to production for a built/deployed instance
NODE_ENV=production
