# Long random value used to sign session cookies — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# GitHub Personal Access Token (optional but recommended — shared across all users of this deployment)
# Without: 60 API requests/hour  |  With: 5,000/hour
GITHUB_TOKEN=

# Path to the SQLite database file (defaults to cloud/server/foss-radar-cloud.db)
DATABASE_PATH=

# Set to "true" once served over HTTPS in production. Keep "false" for local http dev.
SESSION_COOKIE_SECURE=false
